wildcard_constraints:
    chrom = r"\w+",
    chunk = r"\d+",
    ind_filter_id = r"[^.]+",
    site_filter_id = r"[^.]+",
    species = r"orientalis|hofrichteri",
    dataset = r"all_sites|variants"


