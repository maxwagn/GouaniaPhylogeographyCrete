###############################################################################
# Snakefile: species-specific filtered all-sites and variant-only datasets
#
# Purpose
# -------
# This workflow keeps the logic of the original Crete Gouania variant-calling
# pipeline, but makes the final data products explicit and reproducible:
#
#   1. whole-callset, chromosome-wise, filtered ALL-SITES files
#   2. whole-callset, chromosome-wise, filtered VARIANT-SITES files
#   3. species-specific ALL-SITES files using the same filters
#   4. species-specific VARIANT-SITES files using the same filters
#
# The key design choice is that filtering happens ONCE on the full callset.
# Only after genotype-level and site-level filtering do we split into:
#
#   all_sites  -> invariant + variant callable PASS sites
#   variants   -> non-reference/non-invariant PASS sites only
#
# Species-specific datasets are then produced from those two matched products.
# This guarantees that all_sites and variants use exactly the same thresholds,
# sample-level genotype filters, site filters, naming, and chromosome handling.
###############################################################################

import os
import sys
import copy
import yaml
import pysam
import subprocess

import numpy as np
import pandas as pd
from scipy import stats
from matplotlib import pyplot as plt

jn = os.path.join

###############################################################################
# Environment and configuration
###############################################################################

shell.prefix("source /data/antwerpen/grp/asvardal/share/hscon5_setup.sh; ")

configfile: "meta_config/config.yaml"

# Run example:
# snakemake -p --rerun-triggers mtime \
#   --profile ~/.config/snakemake/slurm-simple4 \
#   --rerun-incomplete --keep-going --restart-times 0 | tee run.log

###############################################################################
# Global parameters
###############################################################################

CHROMOSOMES = [str(i) for i in range(1, 25) if i not in [23]]

ind_filter_id = "tif1"
site_filter_id = "sft1"

SPECIES = ["orientalis", "hofrichteri"]

CALLSET_ID = config["callset"]["id"]
REF_NAME = config["ref"]["name"]
VC_ROOT = f"results/VariantCalling/{CALLSET_ID}_{REF_NAME}"

REF_FASTA = config["ref"]["base_fn"] + config["ref"]["ext_fa"]
REF_FAI = config["ref"]["base_fn"] + config["ref"]["ext_fai"]

sample_mt = (
    pd.read_csv(config["sample_mt"], dtype=str, sep="\t")
    .set_index("unique_id", drop=False)
    .drop_duplicates()
)

exclude_IDs = ["lepadogaster_D86"]
sequence_IDS = [i for i in sample_mt["sequence_id"].values if i not in exclude_IDs]
samples = sequence_IDS
n_samples = len(samples)

chunk_size = int(5e6)

chrom_length = pd.read_csv(
    REF_FAI,
    sep="\t",
    usecols=[0, 1],
    names=["chrom", "len"],
    index_col=0,
).squeeze()

max_chrom_length = chrom_length.max()
chunk_to_region = {
    i: (int(i * chunk_size + 1), int((i + 1) * chunk_size))
    for i in range(int(np.ceil(max_chrom_length / chunk_size)))
}


def get_chunks(chrom):
    """Return all chunk IDs needed for one chromosome."""
    return range(int(np.ceil(chrom_length[chrom] / chunk_size)))


def region_for_chunk(wildcards):
    """Return bcftools-compatible region string for one chromosome chunk."""
    start, end = chunk_to_region[int(wildcards.chunk)]
    return f"{wildcards.chrom}:{start}-{end}"


def read_dp(fn):
    """Read a two-column sample/depth file into a dictionary."""
    dp_dic = {}
    with open(fn) as f:
        for line in f:
            sample, dp = line.strip().split()
            dp_dic[sample] = float(dp)
    return dp_dic


def write_dp(fn, samples, dps):
    """Write sample/depth values."""
    with open(fn, "w") as f:
        for sample, dp in zip(samples, dps):
            f.write(f"{sample}\t{dp}\n")


def get_total_dp_files(wildcards):
    """All chunk-level total-depth files needed to estimate mean coverage."""
    return [
        f"{VC_ROOT}/coverage/total_coverage_{chrom}.{chunk}.txt"
        for chrom in CHROMOSOMES
        for chunk in get_chunks(chrom)
    ]


def get_filter_command(wildcards):
    """
    Translate the site-filter section of meta_config/config.yaml into a pipe of
    bcftools soft-filter commands.

    Expected config structure:
      site_filter_sets:
        sft1:
          merge_dist: ...
          filters:
            FilterName:
              tag: MQ
              operator: "<"
              threshold: 30
              threshold_type: absolute
    """
    commands = []
    filters = config["site_filter_sets"][wildcards.site_filter_id]["filters"]

    for filter_name, fd in filters.items():
        assert fd["threshold_type"] == "absolute", (
            "Only absolute site-filter thresholds are currently implemented."
        )
        commands.append(
            "bcftools filter "
            f"--soft-filter {filter_name} "
            "--mode + "
            "-O u "
            f"--exclude '{fd['tag']} {fd['operator']} {fd['threshold']}'"
        )

    return " | ".join(commands)


def subset_file(wildcards):
    """
    Species-specific sample list.

    These files should contain the sample IDs to keep after reheadering, one per
    line, e.g.
      meta_config/subset_orientalis.txt
      meta_config/subset_hofrichteri.txt
    """
    return f"meta_config/subset_{wildcards.species}.txt"


