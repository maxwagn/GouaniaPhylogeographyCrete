rule distance:
    input:
        vcf="input_files/{species}_" + SNP_SUFFIX + ".vcf.gz"
    output:
        dist="results/distance/{species}_" + SNP_SUFFIX + "_maf{maf}.distance_matrix.dist"
    threads: 4
    resources:
        mem_gb=16,
        walltime=1,
    params:
        mem=lambda wildcards, resources: str(int(resources["mem_gb"] * 900)),
        output_base=lambda wildcards, output: os.path.splitext(output["dist"])[0],
        maf_flag=lambda wildcards: f"--maf {wildcards.maf}" if float(wildcards.maf) else "",
    shell:
        r"""
        mkdir -p results/distance
        plink --double-id --threads {threads} --memory {params.mem} \
          {params.maf_flag} \
          --allow-extra-chr \
          --vcf {input.vcf} \
          --out {params.output_base} \
          --distance square
        """


