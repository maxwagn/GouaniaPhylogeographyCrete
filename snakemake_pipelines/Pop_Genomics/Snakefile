###############################################################################
# 5. Sliding-window NJ trees and ASTRAL
###############################################################################

rule window_pwd:
    input:
        vcf="input_files/outgroup/{species}/{species}_" + SNP_SUFFIX + ".chr{chrom}_outgroup.vcf.gz"
    output:
        window_pwd="results/njtrees_hannes/window_pwd.{species}.chrom{chrom}.60000.30000.tsv"
    threads: 1
    resources:
        walltime=72,
        mem_gb=8,
    params:
        window=WINDOW_SIZE,
        step=WINDOW_STEP,
    run:
        os.makedirs("results/njtrees_hannes", exist_ok=True)

        with open(output.window_pwd, "w") as f:
            chrom = wildcards.chrom
            for start in range(0, int(chrom_length.loc[chrom]), params.step):
                end = start + int(params.window)
                d = dv.get_hap_pwd_arr(
                    input.vcf,
                    chrom=wildcards.chrom,
                    start=start,
                    end=end,
                    samples=None,
                    ancestral_sample=None,
                )
                np.savetxt(f, [d], fmt="%i", delimiter="\t")


rule window_pwd_to_tree_file:
    input:
        vcf="input_files/outgroup/{species}/{species}_" + SNP_SUFFIX + ".chr{chrom}_outgroup.vcf.gz",
        window_pwd="results/njtrees_hannes/window_pwd.{species}.chrom{chrom}.60000.30000.tsv",
    output:
        hap_tree_fn="results/njtrees_hannes/window_pwd.{species}.chrom{chrom}.60000.30000.haplotype.newick",
        dip_tree_fn="results/njtrees_hannes/window_pwd.{species}.chrom{chrom}.60000.30000.diploid.newick",
    threads: 1
    resources:
        walltime=12,
        mem_mb=18000,
    run:
        samples = dv.get_samples(vcf_fn=input.vcf)

        with open(input.window_pwd) as f, open(output.hap_tree_fn, "w") as fo, open(output.dip_tree_fn, "w") as fod:
            for line in f.readlines():
                pwd_arr = np.array(line.strip().split())

                hap_pwd_df = dv.hap_pwd_to_df(pwd_arr, samples).fillna(0)
                hap_pwd_df = hap_pwd_df.apply(pd.to_numeric, errors="coerce")

                hap_samples = ["_".join([t[0], str(t[1])]) for t in hap_pwd_df.index]
                tree_newick = dv.get_nj_tree_newick(hap_pwd_df.values, hap_samples)
                fo.write(tree_newick + "\n")

                dip_pwd_df = dv.hap_to_dip(hap_pwd_df)
                dip_pwd_df = dip_pwd_df.apply(pd.to_numeric, errors="coerce")

                tree_newick_dip = dv.get_nj_tree_newick(dip_pwd_df.values, dip_pwd_df.index.values)
                fod.write(tree_newick_dip + "\n")


rule astral_summary:
    input:
        trees=expand(
            "results/njtrees_hannes/window_pwd.{{species}}.chrom{chrom}.60000.30000.diploid.newick",
            chrom=CHROMOSOMES,
        )
    output:
        "results/astral/ASTRAL.{species}.60000.30000.diploid.tre"
    threads: 1
    params:
        tmp="results/astral/{species}.astral.trees.tmp",
        clean_tmp="results/astral/{species}.astral.trees.clean.tmp",
        log="results/astral/{species}.astral.tree.log",
        pop_info="input_files/pop_info/astral_{species}.info",
    shell:
        r"""
        mkdir -p results/astral

        cat results/njtrees_hannes/*{wildcards.species}*.diploid.newick \
          > {params.tmp}

        grep -v '^$' {params.tmp} \
          | grep ';$' \
          | sed "s/'//g" \
          > {params.clean_tmp}

        java -jar bin/ASTRAL/Astral/astral.5.7.8.jar \
          -i {params.clean_tmp} \
          -o {output} \
          -a {params.pop_info} \
          2>{params.log}

        rm -f {params.tmp} {params.clean_tmp}
        """
rule prepare_astral_tree_for_dsuite:
    """
    Prepare rooted, no-support ASTRAL trees for Dsuite/Fbranch.

    For hofrichteri:
      - root by Outgroup
      - keep all populations

    For orientalisNNEMadesignored:
      - start from the full orientalis ASTRAL tree
      - remove NNE-Mades
      - root by Outgroup
      - remove support labels
    """
    input:
        tree=lambda wc: (
            "results/astral/ASTRAL.orientalis.60000.30000.diploid.tre"
            if wc.tree_id == "orientalisNNEMadesignored"
            else f"results/astral/ASTRAL.{wc.tree_id}.60000.30000.diploid.tre"
        )
    output:
        "input_files/ASTRAL.{tree_id}.60000.30000.diploid_woSupport.tre"
    threads: 1
    run:
        from ete3 import Tree

        tree = Tree(str(input.tree), format=1)

        # For orientalis Dsuite/Fbranch, remove the single NNE-Mades population
        # because it is excluded from the D-statistics analysis.
        if wildcards.tree_id == "orientalisNNEMadesignored":
            for leaf in list(tree.iter_leaves()):
                if leaf.name == "NNE-Mades":
                    leaf.delete()

        # Root using the explicit Outgroup population.
        if "Outgroup" in tree.get_leaf_names():
            tree.set_outgroup(tree & "Outgroup")
        else:
            raise ValueError(f"No Outgroup leaf found in {input.tree}")

        # Remove support/internal labels for Dsuite compatibility.
        for node in tree.traverse():
            if not node.is_leaf():
                node.name = ""

        tree.write(outfile=str(output), format=5)

