rule prep_VCF:
    input:
        VCF_DIR + "/{species}_" + ALLSITES_SUFFIX + ".chr{chrom}.vcf.gz"
    output:
        geno="input_files/geno/{species}_" + ALLSITES_SUFFIX + ".chr{chrom}.geno.gz"
    threads: 1
    shell:
        r"""
        mkdir -p input_files/geno

        bin/genomics_general/VCF_processing/parseVCF.py \
          -i {input} \
          | bgzip > {output.geno}
        """


rule popgenWindows:
    input:
        geno="input_files/geno/{species}_" + ALLSITES_SUFFIX + ".chr{chrom}.geno.gz",
        pop_info=lambda wc: pop_info(wc.species),
    output:
        "results/popgenwindows/{species}_" + ALLSITES_SUFFIX +
        ".chr{chrom}.w60000.m100.s30000.Fst.Dxy.pi.csv.gz"
    threads: 8
    resources:
        mem_gb=16,
        walltime=2,
    params:
        populations=lambda wildcards: generate_population_string(wildcards),
    shell:
        r"""
        mkdir -p results/popgenwindows

        bin/genomics_general/popgenWindows.py \
          -g {input.geno} \
          -o {output} \
          -f phased \
          -w {WINDOW_SIZE} \
          -m {WINDOW_MIN_SITES} \
          -s {WINDOW_STEP} \
          {params.populations} \
          --popsFile {input.pop_info} \
          -T {threads} \
          --writeFailedWindows
        """


rule merge_popgenwindows:
    input:
        expand(
            "results/popgenwindows/{{species}}_" + ALLSITES_SUFFIX +
            ".chr{chrom}.w60000.m100.s30000.Fst.Dxy.pi.csv.gz",
            chrom=CHROMOSOMES,
        )
    output:
        "results/popgenwindows/{species}_" + ALLSITES_SUFFIX +
        ".w60000.m100.s30000.Fst.Dxy.pi.dA.csv.gz"
    threads: 1
    params:
        input_prefix="results/popgenwindows/{}_" + ALLSITES_SUFFIX +
        ".chr{}.w60000.m100.s30000.Fst.Dxy.pi.csv.gz"
    run:
        chr1 = params.input_prefix.format(wildcards.species, "1")
        df = pd.read_csv(chr1, compression="gzip")
        reference_header = list(df.columns)

        for ch in CHROMOSOMES:
            if ch == "1":
                continue

            df1 = pd.read_csv(
                params.input_prefix.format(wildcards.species, ch),
                compression="gzip",
            )

            if set(reference_header) != set(df1.columns):
                replace_dic = {}
                for col in set(df1.columns) - set(reference_header):
                    parts = col.split("_")
                    if len(parts) == 3:
                        entry, spec1, spec2 = parts
                        replace_dic[col] = f"{entry}_{spec2}_{spec1}"
                df1.rename(columns=replace_dic, inplace=True)

            if set(reference_header) != set(df1.columns):
                raise ValueError(f"Header mismatch after attempted repair for chromosome {ch}")

            df = pd.concat([df, df1], axis=0)

        dxy_cols = [col for col in df.columns if "dxy" in col]

        for col in dxy_cols:
            _, taxon1, taxon2 = col.split("_")
            df[f"dA_{taxon1}_{taxon2}"] = (
                df[col] - (df[f"pi_{taxon1}"] + df[f"pi_{taxon2}"]) / 2
            )

        os.makedirs("results/popgenwindows", exist_ok=True)
        df.to_csv(str(output), sep="\t", compression="gzip", index=False)


