REFERENCE_FAI = config["reference"]["fai"]
VCF_DIR = config["input_vcfs"]["dir"]

SNP_SUFFIX = config["input_vcfs"]["snp_suffix"]
VARIANT_SUFFIX = config["input_vcfs"]["variant_suffix"]
ALLSITES_SUFFIX = config["input_vcfs"]["allsites_suffix"]
SNP_INDEL_SUFFIX = "variants.tif1.sft1.snps_indels.biallelic"

SPECIES = config["species"]
CHROMOSOMES = config["chromosomes"]

WINDOW_SIZE = config["window"]["size"]
WINDOW_STEP = config["window"]["step"]
WINDOW_MIN_SITES = config["window"]["min_sites"]

MAF = config["maf"]
CLUSTERS = config["admixture_clusters"]
CRETEONLY_CLUSTERS = [2, 3, 4]
POPS = config["populations"]

chrom_length = pd.read_csv(
    REFERENCE_FAI,
    sep="\t",
    usecols=[0, 1],
    names=["chrom", "len"],
    index_col=0,
).squeeze()


def pop_info(species):
    return f"input_files/pop_info/{species}_pop.no_outgroup.info"
#    return f"input_files/pop_info/{species}_pop.info"


def pop_af_info(species):
    return f"input_files/pop_info/{species}_popAF.info"


def generate_population_string(wildcards):
    popmap = pop_info(wildcards.species)
    pops = []
    with open(popmap) as handle:
        for line in handle:
            if not line.strip() or line.startswith("#"):
                continue
            fields = line.strip().split()
            if len(fields) >= 2:
                pops.append(fields[1])
    return " ".join(f"-p {p}" for p in sorted(set(pops)))


