rule genome_wide_het:
    input:
        vcf="input_files/{species}_" + SNP_SUFFIX + ".vcf.gz"
    output:
        "results/heterozygosity_genome/{species}_" + SNP_SUFFIX + ".het"
    threads: 1
    params:
        out="results/heterozygosity_genome/{species}_" + SNP_SUFFIX
    shell:
        r"""
        mkdir -p results/heterozygosity_genome
        vcftools --gzvcf {input.vcf} --het --out {params.out}
        """


rule make_plink:
    input:
        vcf="input_files/{species}_" + SNP_SUFFIX + ".vcf.gz"
    output:
        bed="input_files/plink/{species}_" + SNP_SUFFIX + ".bed",
        freq="input_files/plink/{species}_" + SNP_SUFFIX + ".frq",
        check="input_files/plink/{species}_make_plink.done",
    threads: 1
    params:
        out="input_files/plink/{species}_" + SNP_SUFFIX,
        awk='{$1="0";print $0}',
    shell:
        r"""
        mkdir -p input_files/plink
        plink --vcf {input.vcf} --make-bed --freq --double-id \
          --out {params.out} --allow-extra-chr

        awk '{params.awk}' {params.out}.bim > {params.out}.bim.tmp
        mv {params.out}.bim.tmp {params.out}.bim
        touch {output.check}
        """


rule pca:
    input:
        bed="input_files/plink/{species}_" + SNP_SUFFIX + ".bed",
        freq="input_files/plink/{species}_" + SNP_SUFFIX + ".frq",
    output:
        vec="results/pca/{species}_" + SNP_SUFFIX + ".pca.maf{maf}.eigenvec",
        val="results/pca/{species}_" + SNP_SUFFIX + ".pca.maf{maf}.eigenval",
        checkpoint="results/pca/{species}.maf{maf}.pca.done",
    threads: 4
    resources:
        mem_gb=16,
        walltime=1,
    params:
        mem=lambda wildcards, resources: str(int(resources["mem_gb"] * 900)),
        input_base=lambda wildcards, input: os.path.splitext(input["bed"])[0],
        output_base=lambda wildcards, output: os.path.splitext(output["vec"])[0],
        maf_flag=lambda wildcards: f"--maf {wildcards.maf}" if float(wildcards.maf) else "",
    shell:
        r"""
        mkdir -p results/pca
        plink2 --threads {threads} --memory {params.mem} \
          --set-missing-var-ids @:# \
          --read-freq {input.freq} \
          --chr-set 24 'no-x' 'no-y' 'no-xy' 'no-mt' \
          {params.maf_flag} \
          --bfile {params.input_base} \
          --pca \
          -out {params.output_base}

        touch {output.checkpoint}
        """


rule admixture:
    input:
        bed="input_files/plink/{species}_" + SNP_SUFFIX + ".bed"
    output:
        "results/admixture/admixture_{species}_" + SNP_SUFFIX + ".clusters{cluster}.out"
    threads: 8
    resources:
        walltime=12,
        mem_mb=18000,
    params:
        out="admixture_{species}_" + SNP_SUFFIX + ".clusters{cluster}.out"
    shell:
        r"""
        mkdir -p results/admixture
        cd results/admixture
        ../../bin/admixture_linux-1.3.0/admixture \
          --cv ../../{input.bed} -j{threads} \
          {wildcards.cluster} > {params.out}
        cd ../../
        """

rule create_vcf_subset_CreteOnly:
    """
    Remove Kythira samples from the genome-wide SNP VCF.
    """
    input:
        "input_files/{species}_" + SNP_SUFFIX + ".vcf.gz"
    output:
        vcf="input_files/{species}_" + SNP_SUFFIX + "_CRETEONLY.vcf.gz",
        tbi="input_files/{species}_" + SNP_SUFFIX + "_CRETEONLY.vcf.gz.tbi"
    params:
        samples="input_files/pop_info/{species}_kythira_samples.txt"
    threads: 1
    shell:
        r"""
        bcftools view \
          --samples-file ^{params.samples} \
          -Oz \
          -o {output.vcf} \
          {input}

        tabix -f -p vcf {output.vcf}
        """


rule make_plink_CRETEONLY:
    """
    Convert Crete-only SNP VCF to PLINK format for ADMIXTURE.
    """
    input:
        vcf="input_files/{species}_" + SNP_SUFFIX + "_CRETEONLY.vcf.gz",
        tbi="input_files/{species}_" + SNP_SUFFIX + "_CRETEONLY.vcf.gz.tbi"
    output:
        bed="results/admixture/{species}_CRETEONLY.bed",
        bim="results/admixture/{species}_CRETEONLY.bim",
        fam="results/admixture/{species}_CRETEONLY.fam",
        done="results/admixture/{species}_CRETEONLY_make_plink.done"
    params:
        prefix="results/admixture/{species}_CRETEONLY",
        awk='{$1="0";print $0}'
    threads: 1
    resources:
        mem_gb=8,
        walltime=1
    shell:
        r"""
        mkdir -p results/admixture

        plink \
          --vcf {input.vcf} \
          --make-bed \
          --double-id \
          --out {params.prefix} \
          --allow-extra-chr

        awk '{params.awk}' {output.bim} > {output.bim}.tmp
        mv {output.bim}.tmp {output.bim}

        touch {output.done}
        """


rule admixture_CRETEONLY:
    """
    Run ADMIXTURE for Crete-only samples only.
    """
    input:
        bed="results/admixture/{species}_CRETEONLY.bed",
        bim="results/admixture/{species}_CRETEONLY.bim",
        fam="results/admixture/{species}_CRETEONLY.fam",
        done="results/admixture/{species}_CRETEONLY_make_plink.done"
    output:
        done="results/admixture/{species}_CRETEONLY_admixture{cluster}.done",
        q="results/admixture/{species}_CRETEONLY.{cluster}.Q",
        p="results/admixture/{species}_CRETEONLY.{cluster}.P",
        log="results/admixture/{species}_CRETEONLY.K{cluster}.log"
    params:
        prefix="{species}_CRETEONLY"
    threads: 8
    resources:
        mem_mb=18000,
        walltime=12
    shell:
        r"""
        cd results/admixture

        ../../bin/admixture_linux-1.3.0/admixture \
          --cv \
          -j{threads} \
          {params.prefix}.bed \
          {wildcards.cluster} \
