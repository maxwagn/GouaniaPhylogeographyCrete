rule filter_biallelic_snps_indels:
    input:
        "input_files/{species}_" + VARIANT_SUFFIX + ".vcf.gz"
    output:
        "input_files/{species}_" + SNP_INDEL_SUFFIX + ".vcf.gz"
    threads: 1
    shell:
        r"""
        bcftools view \
          -m2 -M2 \
          -v snps,indels \
          -O z \
          -o {output} \
          {input}

        bcftools index -f --tbi {output}
        """

rule snpEff:
    input:
        "input_files/{species}_" + SNP_INDEL_SUFFIX + ".vcf.gz"
    output:
        "input_files/{species}_" + SNP_INDEL_SUFFIX + ".annSNPEFF.vcf.gz"
    threads: 1
    params:
        db="fGouWil2.1.99",
        report="input_files/{species}_" + SNP_INDEL_SUFFIX + ".annSNPEFF.html",
        tmp="input_files/{species}_" + SNP_INDEL_SUFFIX + ".annSNPEFF.vcf.tmp",
    shell:
        r"""
        java -jar bin/snpEff/snpEff.jar \
          -v {params.db} \
          -stats {params.report} \
          {input} > {params.tmp}

        bcftools view -I {params.tmp} -O z -o {output}
        bcftools index -f --tbi {output}
        rm -f {params.tmp}
        """


rule population_AF_variants:
    input:
        vcf = "input_files/{species}_" + SNP_INDEL_SUFFIX + ".annSNPEFF.vcf.gz",
        popinfo=lambda wc: pop_af_info(wc.species),
    output:
        "results/AF/AF_{species}.tsv.gz"
    threads: 1
    run:
        cmd = (
            f"bcftools +fill-tags {input.vcf} -Ou -- -S {input.popinfo} -t AF "
            "| bcftools view -h"
        )
        header = subprocess.check_output(cmd, shell=True, text=True)
        pops = re.findall(r"ID=(AF_[^,]+)", header)

        header_line = "CHROM\tPOS\tREF\tALT\tANN" + "".join([f"\t{p}" for p in pops])
        spec_AF = "".join([f"\t%INFO/{p}" for p in pops])

        shell(
            f"""
            mkdir -p results/AF
            (
              echo -e '{header_line}'
              bcftools +fill-tags {input.vcf} -Ou -- -S {input.popinfo} -t AF \
                | bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%INFO/ANN{spec_AF}\n'
            ) | bgzip -c > {output}
            """
        )


rule private_fixed_sites:
    input:
        af="results/AF/AF_{species}.tsv.gz"
    output:
        "results/AF/private_fixed_{species}_{focal_pop}.tsv.gz"
    params:
        threshold=0.95,
        pops=["Kythira", "NNE_Mades", "NW_Petres", "SE_Vatos", "SW_Plakias"],
        exclude=[]
    run:
        import pandas as pd
        import os

        os.makedirs("results/private_fixed", exist_ok=True)

        df = pd.read_csv(input.af, sep="\t", low_memory=False)

        af_cols = [f"AF_{p}" for p in params.pops]
        df[af_cols] = df[af_cols].apply(pd.to_numeric, errors="coerce")

        other_pops = [
            p for p in params.pops
            if p != wildcards.focal_pop and p not in params.exclude
        ]

        other_cols = [f"AF_{p}" for p in other_pops]

        case1 = (
            (df[f"AF_{wildcards.focal_pop}"] >= params.threshold) &
            df[other_cols].le(1 - params.threshold).all(axis=1)
        )

        case2 = (
            (df[f"AF_{wildcards.focal_pop}"] <= 1 - params.threshold) &
            df[other_cols].ge(params.threshold).all(axis=1)
        )

        fixed = df[case1 | case2].copy()

        if "ANN" in fixed.columns:
            first_ann = fixed["ANN"].astype(str).str.split(",", n=1).str[0]
            ann_split = first_ann.str.split("|", expand=True)

            fixed["EFFECT"] = ann_split[1]
            fixed["GENE_RAW"] = ann_split[3]

        final_cols = [
            "CHROM", "POS", "REF", "ALT",
            "EFFECT", "GENE_RAW"
        ] + af_cols

        fixed[final_cols].to_csv(
            output[0],
            sep="\t",
            index=False,
            compression="gzip"
        )

