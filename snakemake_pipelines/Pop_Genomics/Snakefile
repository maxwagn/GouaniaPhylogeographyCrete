rule tajimas_d_windows_matrix:
    input:
        vcf="input_files/{species}_" + ALLSITES_SUFFIX + ".vcf.gz",
        windows="results/popgenwindows/{species}_" + ALLSITES_SUFFIX +
                ".w60000.m100.s30000.Fst.Dxy.pi.dA.csv.gz",
        popmap=lambda wc: pop_af_info(wc.species),
    output:
        "results/TajimasD/{species}_" + ALLSITES_SUFFIX +
        ".w60000.m100.s30000.D.tsv.gz"
    threads: 1
    params:
        scaff_col="scaffold",
        start_col="start",
        end_col="end",
        min_sites=100,
        min_maf=0.0,
        min_called_frac=0.6,
    shell:
        r"""
        mkdir -p results/TajimasD

        python bin/tajimas_d_matrix_from_popmap_v2.py \
          --vcf "{input.vcf}" \
          --windows "{input.windows}" \
          --popmap "{input.popmap}" \
          --scaffold-col "{params.scaff_col}" \
          --start-col "{params.start_col}" \
          --end-col "{params.end_col}" \
          --min-sites {params.min_sites} \
          --min-maf {params.min_maf} \
          --min-called-frac {params.min_called_frac} \
          --out "{output}"
        """
